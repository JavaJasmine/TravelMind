# TravelMind Environment Variables
# Copy this file to .env and fill in the values

# Server port (default: 3000)
PORT=3000

# JWT secret — change this to a long random string in production!
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret_string

# Optional: pre-seed the API key via environment (or set it via Admin UI)
# OPENAI_API_KEY=sk-...
